<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <title>Istoric Detaliat Senzor</title>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>

    <style>
        body {
            font-family: 'Segoe UI', Arial;
            padding: 20px;
            background: #ecf0f5;
        }

        .container {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 3px 12px rgba(0,0,0,0.08);
        }

        h1 {
            margin-bottom: 15px;
        }

        .controls {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        select, button {
            padding: 8px 12px;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        button {
            background: #72b06e;
            color: white;
            border: none;
            cursor: pointer;
        }

        canvas {
            height: 400px !important;
        }
    </style>
</head>

<body>

<div class="container">

    <h1 id="titlu-senzor">Istoric</h1>

    <div class="controls">
        <select id="range">
            <option value="day">1 zi</option>
            <option value="week">1 săptămână</option>
            <option value="month">1 lună</option>
        </select>

        <button onclick="randeazaGrafic()">Actualizează</button>
        <button onclick="downloadChart()">Descarcă PNG</button>
    </div>

    <canvas id="graficDetaliat"></canvas>

</div>

<script>

// 🔹 parametru URL
const params = new URLSearchParams(window.location.search);
const sensorType = params.get('sensor') || 'temperature';

// 🔹 denumiri
const sensorNames = {
    temperature: "Temperatură (°C)",
    humidity: "Umiditate (%)",
    pressure: "Presiune (hPa)",
    lux: "Luminozitate (lx)",
    soil_moisture: "Umiditate Sol (%)"
};

document.getElementById('titlu-senzor').innerText =
    "Istoric: " + (sensorNames[sensorType] || sensorType);


// 🔹 EXPORT
function downloadChart() {
    const link = document.createElement('a');
    link.download = sensorType + ".png";
    link.href = document.getElementById('graficDetaliat').toDataURL();
    link.click();
}


// 🔹 GRAFIC
async function randeazaGrafic() {
    try {

        const range = document.getElementById("range").value;

        const res = await fetch(`/get-history?range=${range}`);
        const history = await res.json();

        // 🔥 CONSTRUIRE DATE CORECTĂ (fără desincronizare)
        const labels = [];
        const valori = [];

        history.forEach(h => {
            const val = parseFloat(h[sensorType]);

            // ignoră valori invalide
            if (!isNaN(val) && val !== 0) {
                const dt = new Date(h.data_ora);

                labels.push(
                    dt.toLocaleTimeString('ro-RO', {
                        hour: '2-digit',
                        minute: '2-digit'
                    })
                );

                valori.push(val);
            }
        });

        const ctx = document.getElementById('graficDetaliat').getContext('2d');

        if (window.myChart) window.myChart.destroy();

        window.myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: sensorNames[sensorType],
                    data: valori,

                    borderColor: '#e74c3c',
                    backgroundColor: 'rgba(231,76,60,0.15)',

                    fill: true,
                    tension: 0.35,
                    pointRadius: 2,
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,

                plugins: {
                    legend: { display: true },

                    tooltip: {
                        callbacks: {
                            label: ctx =>
                                ctx.raw + " " + (sensorNames[sensorType] || "")
                        }
                    },

                    zoom: {
                        zoom: {
                            wheel: { enabled: true },
                            pinch: { enabled: true },
                            mode: 'x'
                        },
                        pan: {
                            enabled: true,
                            mode: 'x'
                        }
                    }
                },

                scales: {
                    x: {
                        title: {
                            display: true,
                            text: "Timp"
                        },
                        ticks: {
                            maxRotation: 0,
                            autoSkip: true
                        }
                    },
                    y: {
                        title: {
                            display: true,
                            text: sensorNames[sensorType]
                        }
                    }
                }
            }
        });

    } catch (err) {
        console.error(err);
    }
}

// 🔥 rulare initiala
randeazaGrafic();

</script>

</body>
</html>