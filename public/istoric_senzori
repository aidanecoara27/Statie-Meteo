<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <title>Istoric Detaliat Senzor</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            font-family: 'Segoe UI', Arial;
            padding: 20px;
            background: #ecf0f5;
        }

        .container {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 3px 12px rgba(0,0,0,0.08);
        }

        h1 {
            color: #222d32;
            margin-bottom: 20px;
        }

        canvas {
            height: 400px !important;
        }
    </style>
</head>

<body>

<div class="container">
    <h1 id="titlu-senzor">Istoric</h1>
    <canvas id="graficDetaliat"></canvas>
</div>

<script>

// 🔹 citire parametru din URL
const params = new URLSearchParams(window.location.search);
const sensorType = params.get('sensor') || 'temperature';

// 🔹 denumiri frumoase
const sensorNames = {
    temperature: "Temperatură Aer (°C)",
    humidity: "Umiditate (%)",
    pressure: "Presiune (hPa)",
    lux: "Luminozitate (lx)",
    soil_moisture: "Umiditate Sol (%)"
};

document.getElementById('titlu-senzor').innerText =
    "Istoric: " + (sensorNames[sensorType] || sensorType);


// 🔹 functie grafic
async function randeazaGrafic() {
    try {
        const res = await fetch('/get-history');
        const history = await res.json();

        console.log("Date:", history[0]);

        // 🔥 FILTRARE valori invalide
        const valori = history
            .map(h => parseFloat(h[sensorType]))
            .filter(v => !isNaN(v) && v !== 0);

        // 🔥 TIMP CORECT
        const labels = history.map(h => {
            const dt = new Date(h.data_ora);
            return dt.toLocaleTimeString('ro-RO', {
                hour: '2-digit',
                minute: '2-digit'
            });
        });

        const ctx = document.getElementById('graficDetaliat').getContext('2d');

        if (window.myChart) window.myChart.destroy();

        window.myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: sensorNames[sensorType] || sensorType,
                    data: valori,

                    borderColor: '#e74c3c',
                    backgroundColor: 'rgba(231, 76, 60, 0.15)',

                    fill: true,
                    tension: 0.3,
                    pointRadius: 2,
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,

                interaction: {
                    mode: 'index',
                    intersect: false
                },

                plugins: {
                    legend: {
                        display: true
                    }
                },

                scales: {
                    x: {
                        title: {
                            display: true,
                            text: "Timp"
                        }
                    },
                    y: {
                        beginAtZero: false,
                        title: {
                            display: true,
                            text: sensorNames[sensorType]
                        }
                    }
                }
            }
        });

    } catch (err) {
        console.error("Eroare:", err);
    }
}

// 🔥 IMPORTANT — fără asta NU rulează
randeazaGrafic();

</script>

</body>
</html>